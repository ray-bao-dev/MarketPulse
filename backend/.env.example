# Alpaca API credentials — get these from https://app.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# PostgreSQL (Railway injects DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketpulse

# Sync worker settings
SYNC_INTERVAL_MINUTES=5
BACKFILL_START_DATE=2016-01-01
PRIORITY_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA
SYNC_TIMEFRAMES=1Hour,1Day,1Week

# Optional: use live trading API for asset search (default is paper)
# ALPACA_TRADING_BASE_URL=https://api.alpaca.markets

# Frontend dev server origin for CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173

# Railway sets PORT automatically; used by uvicorn start command
# PORT=8000
