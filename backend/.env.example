# Alpaca API credentials — get these from https://app.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Optional: use live trading API for asset search (default is paper)
# ALPACA_TRADING_BASE_URL=https://api.alpaca.markets

# Frontend dev server origin for CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173

# Railway sets PORT automatically; used by uvicorn start command
# PORT=8000
